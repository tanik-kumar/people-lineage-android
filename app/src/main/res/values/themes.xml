<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PeopleLineage" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/surface_tint</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary_dark</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/surface_container</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        <item name="colorTertiary">@color/brand_accent</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/divider_soft</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface_warm</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:windowBackground">@drawable/bg_screen</item>
        <item name="materialCardViewStyle">@style/Widget.PeopleLineage.Card</item>
        <item name="materialButtonStyle">@style/Widget.PeopleLineage.Button</item>
        <item name="toolbarStyle">@style/Widget.PeopleLineage.Toolbar</item>
    </style>

    <style name="Widget.PeopleLineage.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">20dp</item>
    </style>

    <style name="Widget.PeopleLineage.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.PeopleLineage.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
    </style>
    <style name="Widget.PeopleLineage.Dropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu" />
</resources>
