<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="20dp"
    app:strokeColor="@color/divider_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="104dp"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/nameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            tools:text="Abdul Rahman" />

        <TextView
            android:id="@+id/addressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            tools:text="Village Banshgram • Murshidabad, West Bengal" />

        <TextView
            android:id="@+id/metaText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="@color/brand_primary"
            tools:text="Phone: 9876543210" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
